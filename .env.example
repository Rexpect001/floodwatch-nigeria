# ============================================================
# Nigeria Climate Early Warning System — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# Database (PostGIS)
DB_PASSWORD=your_secure_db_password_here
DATABASE_URL=postgresql://climate_user:your_password@localhost:5432/climate_ews

# Redis
REDIS_URL=redis://localhost:6379

# ── TIER 1: Government APIs ───────────────────────────────
# NIHSA (Nigerian Hydrological Services Agency)
NIHSA_BASE_URL=https://api.nihsa.gov.ng/v1
NIHSA_API_KEY=your_nihsa_api_key

# NiMet (Nigerian Meteorological Agency)
NIMET_API_KEY=your_nimet_api_key
NIMET_BASE_URL=https://api.nimet.gov.ng/v1

# NEMA (National Emergency Management Agency)
NEMA_API_KEY=your_nema_api_key
NEMA_WEBHOOK_SECRET=your_nema_webhook_secret

# ── TIER 2: Global Validation ─────────────────────────────
# Google Flood Hub API
GOOGLE_FLOOD_HUB_KEY=your_google_flood_hub_key

# GloFAS (Copernicus)
GLOFAS_API_KEY=your_glofas_key

# OpenWeatherMap One Call 3.0 (1,000 calls/day free tier)
OWM_API_KEY=your_owm_api_key

# ── ALERTS: SMS & Push ────────────────────────────────────
# Africa's Talking (Primary SMS — MTN/Airtel/Glo/9mobile)
AT_USERNAME=your_at_username
AT_API_KEY=your_at_api_key
AT_SENDER_ID=FloodWatchNG

# Twilio (Fallback SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_FROM=+1234567890

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Firebase (Push Notifications)
FIREBASE_SERVER_KEY=your_firebase_server_key

# ── VERIFICATION ─────────────────────────────────────────
# OpenAI (CBEWS photo flood detection)
OPENAI_API_KEY=your_openai_api_key

# ── SECURITY ──────────────────────────────────────────────
JWT_SECRET=your_minimum_32_char_jwt_secret_here

# ── VOICE PIPELINE ───────────────────────────────────────
# Anthropic (Claude API — translation batch processing)
ANTHROPIC_API_KEY=your_anthropic_api_key
# Model: claude-opus-4-6 (per CLAUDE.md directive)

# Google Cloud Text-to-Speech
GOOGLE_CLOUD_TTS_KEY=your_google_cloud_tts_key

# Coqui TTS (Tier 2 — Q2 2026, self-hosted Hausa VITS)
COQUI_ENDPOINT=http://coqui-service:5002/api/tts

# S3 bucket for voice clips (Standard-IA, 30-day lifecycle)
VOICE_S3_BUCKET=nimet-plus-alerts
CLOUDFRONT_DOMAIN=your_cloudfront_domain.cloudfront.net

# RabbitMQ (alert dispatch queue)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# TOTP secrets for emergency override (one per DIRECTOR officer ID)
# TOTP_SECRET_{OFFICER_ID}=base32_secret_here
TOTP_SECRET_DEFAULT=BASE32SECRETHERE

# ── MONITORING ────────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_admin_password

# ── DEPLOYMENT ───────────────────────────────────────────
# AWS Lagos region (af-south-1) or Azure South Africa North
AWS_REGION=af-south-1
AWS_DEFAULT_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# ── RABBITMQ CREDENTIALS ────────────────────────────────
RABBITMQ_USER=climate
RABBITMQ_PASS=your_rabbitmq_password

# ── AFRICA'S TALKING VOICE ───────────────────────────────
AT_CALLER_ID=+234800000000

# ── IVR SYSTEM ──────────────────────────────────────────
IVR_UPDATE_ENDPOINT=https://your-ivr-system.example.com/api/update

# ── RADIO FTP TARGETS (JSON array) ──────────────────────
# Format: [{"host":"ftp.station.ng","user":"ftp_user","password":"ftp_pass","path":"/alerts/","station_name":"Rhythm FM"}]
RADIO_FTP_TARGETS=[]

# ── FRONTEND (Vite) ──────────────────────────────────────
VITE_API_BASE_URL=/api/v1
REACT_APP_MAPBOX_TOKEN=your_mapbox_public_token
REACT_APP_SAR_WMS_URL=

# ── GOOGLE APPLICATION CREDENTIALS ──────────────────────
# Path to GCP service account JSON (for Cloud TTS)
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-credentials.json

# ── API GATEWAY ──────────────────────────────────────────
UVICORN_WORKERS=4
LOG_LEVEL=info
