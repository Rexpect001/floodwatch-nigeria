{
  "version": 2,
  "name": "floodwatch-nigeria",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://floodwatch-api-is3d.onrender.com/api/:path*"
    },
    {
      "source": "/maps/:path*",
      "destination": "https://floodwatch-api-is3d.onrender.com/maps/:path*"
    },
    {
      "source": "/((?!api|maps|assets|icons|screenshots|manifest\\.json|service-worker\\.js|offline\\.html).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/maps/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://floodwatch-api-is3d.onrender.com/api/v1",
    "REACT_APP_MAPBOX_TOKEN": "@mapbox_token",
    "REACT_APP_SAR_WMS_URL": "@sar_wms_url"
  }
}
